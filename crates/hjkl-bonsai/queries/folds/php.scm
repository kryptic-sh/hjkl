; PHP folds query — @fold marks foldable multi-line nodes.

(function_definition) @fold
(method_declaration) @fold
(class_declaration) @fold
(interface_declaration) @fold
(trait_declaration) @fold
(enum_declaration) @fold

(compound_statement) @fold
(if_statement) @fold
(for_statement) @fold
(foreach_statement) @fold
(while_statement) @fold
(switch_statement) @fold
(try_statement) @fold
